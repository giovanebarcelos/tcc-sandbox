' TCC16-AFDdoScanner.puml | Aula 16
' O scanner como AFD: estados de reconhecimento de tokens — versão PlantUML
@startuml
skinparam state {
    BackgroundColor #F0F4F8
    BorderColor #2563EB
}
[*] --> Inicio
Inicio --> Num : dígito
Inicio --> Id : letra/_
Inicio --> Op : + - * / =
Inicio --> Punct : ( ) { } ;
Inicio --> Comentario : #
Inicio --> Inicio : espaço
Num --> Num : dígito
Num --> Inicio : outro → emite NUM
Id --> Id : letra/dígito/_
Id --> Inicio : outro → emite ID/KEYWORD
Op --> Inicio : emite OP
Punct --> Inicio : emite PUNCT
Comentario --> Comentario : não-\n
Comentario --> Inicio : \n
Inicio --> [*] : EOF
@enduml
